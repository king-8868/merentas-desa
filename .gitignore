# Runtime data - regenerated automatically on first run (see lib/init-data.js).
# Committing live race-day data (student names, results, password hashes,
# etc.) to source control doesn't make sense - it's state, not code. This
# ignores everything under data/, any file type, at any depth - including
# archived event snapshots under data/archive/<timestamp>/, which hold the
# exact same kind of real student data as the live files.
/data/**

# 1.4: automatic disaster-recovery snapshots (see lib/backup.js) - holds the
# exact same kind of real data (password hashes, student records) as /data,
# just short-lived and routinely pruned. Same reasoning, same treatment -
# this was missed when /backup was introduced and is fixed here.
/backup/**

# v1.9.0 acceptance testing: ad-hoc `data.snapshot-*` folders (plain `cp -r
# data data.snapshot-...` copies made before/after a manual test pass) hold
# the exact same real password hashes/student data as /data itself, but
# `/data/**` above doesn't catch them since they're sibling directories, not
# nested inside data/. Same reasoning, same treatment.
/data.snapshot-*/

# v1.9.0: first real npm dependency this project has ever had (pdf-lib).
# node_modules is installed by `npm install` from package-lock.json - never
# hand-edited, never something to version - so it's excluded the same way
# every other Node project excludes it.
/node_modules/

# v1.9.1: Windows update packages built by prepare-windows-update.sh - pure
# build output (a copy of already-committed source), regenerated on demand,
# never something to version. Same reasoning as a dist/ or build/ folder.
/Windows_Update_v*/
/Merentas_Desa_Update_v*.zip

# Windows-side artifacts of Update_System.bat / RESTORE_LAST_BACKUP.bat if
# this repo is ever opened from a school's Windows checkout - these hold the
# exact same real data/code snapshots as /backup, just under the updater's
# own folder name. Never relevant on Mac/Railway, included for safety.
/new_version/
/backup_before_update/**

# OS junk
.DS_Store

# Editor
.vscode/
.idea/
