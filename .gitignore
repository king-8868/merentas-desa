# Runtime data - regenerated automatically on first run (see lib/init-data.js).
# Committing live race-day data (student names, results, password hashes,
# etc.) to source control doesn't make sense - it's state, not code. This
# ignores everything under data/, any file type, at any depth - including
# archived event snapshots under data/archive/<timestamp>/, which hold the
# exact same kind of real student data as the live files.
/data/**

# 1.4: automatic disaster-recovery snapshots (see lib/backup.js) - holds the
# exact same kind of real data (password hashes, student records) as /data,
# just short-lived and routinely pruned. Same reasoning, same treatment -
# this was missed when /backup was introduced and is fixed here.
/backup/**

# OS junk
.DS_Store

# Editor
.vscode/
.idea/
